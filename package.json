{
  "name": "jusic-artist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.cjs",
    "import:artists": "node scripts/import-artists.cjs",
    "db:init": "node scripts/init-db.cjs",
    "db:seed": "node scripts/seed-neon.cjs",
    "db:replace": "node scripts/replace-all-artists.cjs",
    "classify:buckets": "node scripts/classify-artist-buckets.cjs",
    "start": "node server/index.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-virtual": "^3.13.26",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
